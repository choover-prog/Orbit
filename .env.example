# Fixture is the safe default and performs no network request.
# Set to live only to evaluate the read-only Open-Meteo sandbox at Orbit's
# fixed, coarse fictional test location. No API key or personal location is used.
ORBIT_WEATHER_MODE=fixture

# Publisher/build configuration for the Google Calendar connector. End users
# never edit these values. Local maintainers provision the Desktop OAuth client
# metadata only in ignored .env.local; neither value is committed or browser-visible.
ORBIT_GOOGLE_CALENDAR_MODE=fixture
ORBIT_GOOGLE_CALENDAR_CLIENT_ID=
ORBIT_GOOGLE_CALENDAR_CLIENT_SECRET=
ORBIT_GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:3000

# Publisher/build configuration for the independent Gmail connector. Gmail's
# restricted read-only scope is used only for a private, local qualification.
# These values are server-owned and never entered by an end user.
ORBIT_GOOGLE_GMAIL_MODE=fixture
ORBIT_GOOGLE_GMAIL_CLIENT_ID=
ORBIT_GOOGLE_GMAIL_CLIENT_SECRET=
ORBIT_GOOGLE_GMAIL_REDIRECT_URI=http://127.0.0.1:3000

# Google Nest Device Access (publisher-provisioned; never commit real values)
ORBIT_GOOGLE_NEST_MODE=fixture
ORBIT_GOOGLE_NEST_CLIENT_ID=
ORBIT_GOOGLE_NEST_CLIENT_SECRET=
ORBIT_GOOGLE_NEST_PROJECT_ID=
ORBIT_GOOGLE_NEST_REDIRECT_URI=http://127.0.0.1:3000
