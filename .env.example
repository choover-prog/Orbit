# Fixture is the safe default and performs no network request.
# Set to live only to evaluate the read-only Open-Meteo sandbox at Orbit's
# fixed, coarse fictional test location. No API key or personal location is used.
ORBIT_WEATHER_MODE=fixture

# Google Calendar is fixture-first and performs no Google request by default.
# Live mode is a local-only Windows evaluation with a Google Desktop OAuth
# client. Put real values only in ignored .env.local; never commit credentials.
ORBIT_GOOGLE_CALENDAR_MODE=fixture
ORBIT_GOOGLE_CALENDAR_CLIENT_ID=
ORBIT_GOOGLE_CALENDAR_REDIRECT_URI=http://127.0.0.1:3000
